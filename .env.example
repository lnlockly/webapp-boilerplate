# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/webapp?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Backend
BACKEND_PORT=3000
JWT_SECRET=replace-with-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
COOKIE_SECRET=replace-with-another-long-random-string

# Frontend (Vite — only VITE_* vars are exposed to client)
VITE_API_URL=http://localhost:3000
VITE_APP_NAME=AppX

# Email (Resend). Without key → console.log in dev.
RESEND_API_KEY=
EMAIL_FROM="AppX <noreply@example.com>"

# OAuth (placeholders — wire when enabled in app.config.ts)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OAUTH_REDIRECT_BASE=http://localhost:3000

# Stripe (test-mode keys). Without key → /billing routes return 503.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=http://localhost:5173/settings/billing?status=success
STRIPE_CANCEL_URL=http://localhost:5173/settings/billing?status=cancel

# S3-compatible storage (placeholder — falls back to local /uploads).
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=us-east-1
S3_PUBLIC_URL=

# Observability
SENTRY_DSN=
LOG_LEVEL=info
