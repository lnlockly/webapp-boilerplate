{
  "name": "webapp-boilerplate",
  "version": "0.1.0",
  "private": true,
  "description": "Production-grade SaaS web-app boilerplate (Vite React 19 + NestJS 11 + Prisma + Stripe + multi-tenant).",
  "packageManager": "pnpm@9.12.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --parallel -r run dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "test": "pnpm -r run test",
    "prisma:migrate": "pnpm --filter @app/backend exec prisma migrate dev",
    "prisma:generate": "pnpm --filter @app/backend exec prisma generate",
    "format": "prettier --write \"apps/**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.10.0",
    "pnpm": ">=9.0.0"
  }
}
